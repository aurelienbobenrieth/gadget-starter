{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "arrowParens": "always",
  "tsdoc": true,
  "sortPackageJson": {},
  "ignorePatterns": ["**/*.d.ts", "**/*.generated.*", "accessControl", "yarn.lock"]
}
